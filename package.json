{
  "name": "atlas",
  "version": "1.0.0",
  "description": "AI writing agent with evaluator feedback loop",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "marker-writer": "tsx src/marker_writer/index.ts",
    "marker-writer:cli": "tsx src/marker_writer/cli.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:marker-writer": "tsx tests/test-prompts.ts --all",
    "test:basic_position": "tsx tests/test-prompts.ts --category BASIC_POSITION",
    "test:mid_sentence": "tsx tests/test-prompts.ts --category MID_SENTENCE",
    "test:between_sections": "tsx tests/test-prompts.ts --category BETWEEN_SECTIONS",
    "test:mid_paragraph": "tsx tests/test-prompts.ts --category MID_PARAGRAPH",
    "test:multi_language": "tsx tests/test-prompts.ts --category MULTI_LANGUAGE",
    "test:content_type": "tsx tests/test-prompts.ts --category CONTENT_TYPE",
    "test:paired_markers": "tsx tests/test-prompts.ts --category PAIRED_MARKERS",
    "test:edge_case": "tsx tests/test-prompts.ts --category EDGE_CASE",
    "test:voice_matching": "tsx tests/test-prompts.ts --category VOICE_MATCHING",
    "test:single": "tsx tests/test-prompts.ts",
    "example:all": "tsx tests/run-examples.ts --all",
    "example:continue": "tsx tests/run-examples.ts --category continue",
    "example:insert": "tsx tests/run-examples.ts --category insert",
    "example:rewrite": "tsx tests/run-examples.ts --category rewrite",
    "example:expand": "tsx tests/run-examples.ts --category expand",
    "example:delete": "tsx tests/run-examples.ts --category delete",
    "example:generate": "tsx tests/run-examples.ts --category generate",
    "example:inline": "tsx tests/run-examples.ts --category inline",
    "example:list": "tsx tests/run-examples.ts --list",
    "test": "vitest run",
    "test:integration": "vitest run --include 'tests/integration/**/*.test.ts'",
    "test:e2e": "vitest run --include 'tests/e2e/**/*.test.ts' --testTimeout 120000"
  },
  "dependencies": {
    "@langchain/anthropic": "^0.3.34",
    "@langchain/core": "^0.3.0",
    "@langchain/langgraph": "^0.2.0",
    "@langchain/openai": "^0.2.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "prettier": "^3.8.1",
    "tsx": "^4.7.0",
    "typescript": "^5.5.0",
    "vitest": "^4.0.18"
  }
}
